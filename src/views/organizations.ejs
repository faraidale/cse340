<%- include('partials/header') %>
<h1><%= title %></h1>
<p>Here are a few of our partner organizations:</p>
<ul>
  <% organizations.forEach(organization => { %>
    <li>
      <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
      <strong><a href="/organization/<%= organization.organization_id %>"><%= organization.name %></a></strong>: <%= organization.contact_email %>
      <p><%= organization.description %></p>
    </li>
  <% }); %>
</ul>
<%- include('partials/footer') %>